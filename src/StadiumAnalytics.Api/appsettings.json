{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "StadiumAnalytics": "Debug"
    }
  },
  "ConnectionStrings": {
    "StadiumDb": "Data Source=stadium.db"
  },
  "Application": {
    "PathBase": ""
  },
  "EventChannel": {
    "Capacity": 1000,
    "HighWaterMark": 800
  },
  "EventConsumer": {
    "ShutdownDrainTimeoutSeconds": 10
  },
  "EventSimulation": {
    "Enabled": true,
    "IntervalSeconds": 60
  },
  "AllowedHosts": "*"
}
